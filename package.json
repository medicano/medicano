{
  "name": "medicano",
  "version": "1.0.0",
  "description": "Medicano project frontend and backend",
  "private": true,
  "homepage": "https://github.com/medicano/medicano-project#readme",
  "bugs": {
    "url": "https://github.com/medicano/medicano-project/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medicano/medicano-project.git"
  },
  "license": "MIT",
  "author": "Medicano Development Group",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces --if-present",
    "types:build": "npm run build --workspace=packages/types",
    "types:dev": "npm run dev --workspace=packages/types"
  }
}

              "raw": "{{baseUrl}}/appointments?clinicId={{clinicId}}",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "clinicId",       "value": "{{clinicId}}",       "disabled": false },

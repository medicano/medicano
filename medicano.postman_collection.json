          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinicId\": \"{{clinicId}}\",\n  \"username\": \"atendente1\",\n  \"password\": \"senha1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login/attendant", "host": ["{{baseUrl}}"], "path": ["auth", "login", "attendant"] }

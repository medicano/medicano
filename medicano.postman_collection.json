              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinicId\": \"{{clinicId}}\",\n  \"professionalId\": \"{{professionalId}}\",\n  \"patientId\": \"{{patientId}}\",\n  \"startAt\": \"2026-05-10T09:00:00.000Z\",\n  \"durationMinutes\": 30,\n  \"notes\": \"Primeira consulta\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] },
            "description": "Role: clinic | attendant. durationMinutes: 15–480."
          }
        },
        {
          "name": "List Appointments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments?clinicId={{clinicId}}",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "clinicId",        "value": "{{clinicId}}",       "disabled": false },
                { "key": "professionalId",  "value": "{{professionalId}}", "disabled": true },
                { "key": "patientId",       "value": "{{patientId}}",      "disabled": true },
                { "key": "date",            "value": "2026-05-10",         "disabled": true },
                { "key": "dateFrom",        "value": "2026-05-01",         "disabled": true },
                { "key": "dateTo",          "value": "2026-05-31",         "disabled": true },
                { "key": "status",          "value": "scheduled",          "disabled": true }
              ]
            },
            "description": "status: scheduled | confirmed | completed | cancelled"
          }
        },
